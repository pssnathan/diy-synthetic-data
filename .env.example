# --- LLM provider (OpenAI-compatible API) ---
# auto: Groq if GROQ_API_KEY set, else OpenRouter if OPENROUTER_API_KEY set, else OpenAI
LLM_PROVIDER=auto

# Groq (recommended first — typically lower cost / fast inference)
GROQ_API_KEY=groq_api_key
# Optional override (default is Groq’s OpenAI-compatible endpoint)
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenRouter (https://openrouter.ai/docs — OpenAI-compatible)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional headers for OpenRouter rankings/analytics:
# OPENROUTER_HTTP_REFERER=https://github.com/yourname/yourrepo
# OPENROUTER_APP_NAME=mini-project-DIY

# OpenAI (set LLM_PROVIDER=openai or rely on auto after unsetting Groq + OpenRouter keys)
# OPENAI_API_KEY=sk-replace-with-your-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Models — must match the provider (see each host’s model list)
# Groq: GENERATION_MODEL=llama-3.3-70b-versatile
# OpenRouter: GENERATION_MODEL=meta-llama/llama-3.1-8b-instruct
# OpenAI: GENERATION_MODEL=gpt-4o-mini
# JUDGE_MODEL=... (same or different)
